/* ═══════════════════════════════════════════════════════════════
   snip.tcss  —  single source of truth for all visual styling
   Colors are provided via CSS variables ($snip-*) injected at
   runtime from the active theme (see snip/themes.py).

   Default palette (Tokyo Night):
     bg:           #0d0f18   surface:      #0a0b14
     panel:        #13141f   border:       #2a2c42
     border-dim:   #1a1c2e   select-bg:    #131729
     accent:       #7aa2f7   teal:         #73daca
     purple:       #bb9af7   pill-bg:      #252640
     text:         #c0caf5   text-hi:      #e0e7ff
     text-mid:     #a0aabf   text-muted:   #565f89
     text-dim:     #3b3f5c   text-ghost:   #2a2c42

   Border rule: every `border-*: tall` costs 1 row.
   widget height = visible content rows + border rows.
   ═══════════════════════════════════════════════════════════════ */


/* ── Global ─────────────────────────────────────────────────── */

Screen {
    background: $snip-bg;
    layers: base overlay;
}


/* ── AppHeader ──────────────────────────────────────────────── */

/* height 3 = 1 top-pad + 1 content + 1 border-bottom */
AppHeader {
    dock: top;
    height: 3;
    background: $snip-bg;
    border-bottom: tall $snip-border;
    padding: 1 2 0 2;
}


/* ── Footer ─────────────────────────────────────────────────── */

/* height 2 = 1 border-top row + 1 content row */
Footer {
    height: 2;
    background: $snip-panel;
    color: $snip-text-muted;
    border-top: tall $snip-border;
}

FooterKey {
    background: $snip-panel;
    color: $snip-text-muted;
}

FooterKey .footer-key--key {
    color: $snip-accent;
    background: $snip-pill-bg;
}

FooterKey:hover .footer-key--key {
    background: $snip-accent;
    color: $snip-bg;
}


/* ── MainScreen ─────────────────────────────────────────────── */

/* search bar — height 3: 1 top-pad + 1 text + 1 border-bottom */
MainScreen .search-bar {
    height: 3;
    background: $snip-surface;
    border-bottom: tall $snip-border;
    padding: 1 2 0 2;
    overflow: hidden;
}

MainScreen .search-label {
    color: $snip-accent;
    text-style: bold;
    width: auto;
    min-width: 2;
}

/* Use the ID to override Textual's own Input default CSS */
#search-input {
    background: transparent;
    border: none;
    color: $snip-text;
    height: 1;
    min-width: 8;
    padding: 0;
    width: 1fr;
}

#search-input:focus {
    background: transparent;
    border: none;
}

#search-input .input--placeholder {
    color: $snip-text-dim;
}

/* panels */
MainScreen .panels {
    height: 1fr;
    min-height: 4;
}

/* status bar — height 2: border-top (row 0) + text (row 1) */
MainScreen .status-bar {
    height: 2;
    background: $snip-surface;
    border-top: tall $snip-border;
    color: $snip-text-dim;
    padding: 0 2;
}

/* too-small overlay */
MainScreen #too-small-overlay {
    layer: overlay;
    display: none;
    width: 100%;
    height: 100%;
    background: $snip-bg;
    align: center middle;
}

MainScreen #too-small-overlay Static {
    color: $snip-text-muted;
    text-align: center;
    width: auto;
}


/* ── SnippetList ─────────────────────────────────────────────── */

SnippetList {
    width: 33%;
    min-width: 24;
    background: $snip-bg;
    border-right: tall $snip-border;
}

/* height 3: 1 top-pad + 1 text + 1 border-bottom */
SnippetList .panel-label {
    height: 3;
    background: $snip-surface;
    border-bottom: tall $snip-border-dim;
    color: $snip-text-ghost;
    padding: 1 2 0 2;
}

SnippetList ListView {
    background: $snip-bg;
    border: none;
    height: 1fr;
    padding: 0;
}

SnippetList .empty-label {
    color: $snip-text-dim;
    padding: 4 2;
    text-align: center;
}


/* ── SnippetItem ─────────────────────────────────────────────── */

/*
  height 4, padding 1 2 0 2, border-bottom: tall
  content rows = 4 - 1(border) - 1(pad-top) - 0(pad-bot) = 2
  row 0: item-title  row 1: item-meta
*/
SnippetItem {
    background: $snip-bg;
    border-bottom: tall $snip-border-dim;
    height: 4;
    padding: 1 2 0 2;
}

SnippetItem:hover {
    background: $snip-hover-bg;
}

SnippetItem.-highlighted {
    background: $snip-select-bg;
    border-left: tall $snip-accent;
    padding-left: 1;
}

SnippetItem.-highlighted .item-title {
    color: $snip-text-hi;
}

SnippetItem .item-title {
    color: $snip-text-mid;
    height: 1;
    text-style: bold;
}

SnippetItem .item-meta {
    color: $snip-text-dim;
    height: 1;
}


/* ── SnippetPreview ──────────────────────────────────────────── */

SnippetPreview {
    background: $snip-bg;
    overflow-y: auto;
    padding: 1 2;
    width: 1fr;
}

SnippetPreview #preview-header {
    height: auto;
    margin-bottom: 1;
    color: $snip-text;
}

/* round border gives ╭─╮╰─╯ corners */
SnippetPreview .preview-code-wrap {
    background: $snip-surface;
    border: round $snip-border;
    margin: 0 0 1 0;
    padding: 0 1;
}

SnippetPreview #preview-footer {
    height: auto;
    color: $snip-text-muted;
}


/* ── EditScreen ──────────────────────────────────────────────── */

EditScreen {
    align: center middle;
    background: $snip-bg;
}

EditScreen > Vertical {
    background: $snip-panel;
    border: tall $snip-border;
    height: 90%;
    overflow-y: auto;
    padding: 1 3;
    width: 84;
}

EditScreen .modal-title {
    color: $snip-accent;
    height: auto;
    margin-bottom: 1;
    text-style: bold;
}

EditScreen .modal-divider {
    color: $snip-text-ghost;
    height: 1;
}

EditScreen .form-label {
    color: $snip-text-muted;
    height: 1;
}

EditScreen Input {
    background: $snip-bg;
    border: tall $snip-border;
    color: $snip-text;
    margin-bottom: 1;
}

EditScreen Input:focus {
    background: $snip-surface;
    border: tall $snip-accent;
}

EditScreen Select {
    margin-bottom: 1;
}

EditScreen Select:focus {
    border: tall $snip-accent;
}

EditScreen TextArea {
    background: $snip-bg;
    border: tall $snip-border;
    height: 14;
    margin-bottom: 1;
}

EditScreen TextArea:focus {
    border: tall $snip-accent;
}

EditScreen .btn-row {
    align: right middle;
    height: 3;
    padding-top: 1;
}

EditScreen Button {
    margin-left: 1;
}

EditScreen #btn-save {
    background: $snip-accent;
    border: none;
    color: $snip-bg;
}

EditScreen #btn-save:hover {
    background: $snip-accent-hover;
}

EditScreen #btn-cancel {
    background: $snip-pill-bg;
    border: none;
    color: $snip-text-muted;
}

EditScreen #btn-cancel:hover {
    background: $snip-pill-bg-hover;
    color: $snip-text;
}
